{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "ES2020",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "types": ["node"],

    "sourceMap": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "noImplicitAny": true,

    "strictNullChecks": true
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}
